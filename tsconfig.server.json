{
  "compilerOptions": {
    "declaration": true,
    "lib": ["ES2024", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noUncheckedIndexedAccess": true,
    "outDir": "dist/server",
    "rootDir": "src",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2024"
  },
  "include": ["src/server", "src/shared"]
}
