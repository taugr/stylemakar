{
  "name": "stylemakar",
  "version": "0.1.1",
  "description": "Local-first style rewriting app with an LM Studio-backed rewrite pipeline.",
  "keywords": [
    "lm-studio",
    "react",
    "rewrite-pipeline",
    "style-rewriter",
    "typescript",
    "vite"
  ],
  "homepage": "https://github.com/taugr/stylemakar#readme",
  "bugs": {
    "url": "https://github.com/taugr/stylemakar/issues"
  },
  "license": "MIT",
  "author": "Tom Auger <tom@tau.gr>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taugr/stylemakar.git"
  },
  "bin": {
    "stylemakar": "dist/cli.js"
  },
  "files": [
    "dist",
    ".agents/skills/stylemakar-cli/SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "cli:build": "tsdown",
    "cli:dev": "tsx src/cli.ts",
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"tsx watch src/server/index.ts\"",
    "dev:api": "tsx watch src/server/index.ts",
    "eval": "pnpm eval:seed && pnpm eval:rewrite",
    "eval:iterations": "pnpm eval:seed && tsx evals/scripts/run-iteration-eval.ts",
    "eval:iterations:matrix": "pnpm eval:seed && tsx evals/scripts/run-iteration-matrix.ts",
    "eval:rewrite": "promptfoo eval -c evals/promptfoo.yaml",
    "eval:seed": "tsx evals/scripts/seed-eval-data.ts",
    "eval:smoke": "pnpm eval:seed && promptfoo eval -c evals/promptfoo-smoke.yaml",
    "eval:personalisation": "tsx evals/scripts/check-personalisation.ts",
    "eval:view": "promptfoo view",
    "eval:v2:validate": "tsx evals/scripts/validate-dataset.ts",
    "eval:v2:report": "tsx evals/scripts/build-eval-report.ts",
    "eval:v2:judge": "tsx evals/scripts/judge-dataset.ts",
    "eval:v2:judge-report": "tsx evals/scripts/build-judge-report.ts",
    "eval:v2:human-review": "tsx evals/scripts/build-human-review.ts",
    "eval:v2:human-summary": "tsx evals/scripts/summarize-human-review.ts",
    "eval:v2:case-review": "tsx evals/scripts/build-case-review-queue.ts",
    "eval:v2:release-gate": "tsx evals/scripts/check-release-thresholds.ts",
    "eval:v2:profile-differentiation": "tsx evals/scripts/check-profile-differentiation.ts",
    "eval:v2:smoke": "pnpm eval:v2:validate && tsx evals/scripts/run-dataset.ts --split validation --method no-op",
    "eval:v2:validation": "pnpm eval:v2:validate && tsx evals/scripts/run-dataset.ts --split validation --method no-op,one-shot,full-pipeline",
    "eval:v2:release": "pnpm eval:v2:validate && tsx evals/scripts/run-dataset.ts --split holdout --method no-op,one-shot,full-pipeline --repeat 3",
    "build": "tsc --noEmit && vite build && pnpm cli:build",
    "desktop:bundle:mac": "node scripts/build-unsigned-macos-dmg.mjs",
    "desktop:build": "tauri build",
    "desktop:check": "pnpm typecheck && cargo check --manifest-path src-tauri/Cargo.toml",
    "desktop:dev": "tauri dev",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "start": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "format": "oxfmt . --check",
    "format:fix": "oxfmt . --write",
    "lint": "oxlint -c oxlint.json .",
    "lint:fix": "oxlint -c oxlint.json . --fix",
    "prepare": "node scripts/prepare.mjs",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@vitejs/plugin-react": "^6.0.3",
    "commander": "^15.0.0",
    "concurrently": "^10.0.3",
    "express": "^5.2.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.23.1",
    "vite": "^8.1.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "playwright": "^1.61.1",
    "promptfoo": "^0.121.19",
    "tsdown": "^0.22.9",
    "typescript": "^7.0.2",
    "vitepress": "^1.6.4",
    "vitepress-plugin-group-icons": "^1.7.5",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": ">=22.22.1"
  },
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25"
}
