{
  "name": "stylemakar",
  "version": "0.1.0",
  "description": "Local-first style rewriting app with an LM Studio-backed rewrite pipeline.",
  "keywords": [
    "lm-studio",
    "react",
    "rewrite-pipeline",
    "style-rewriter",
    "typescript",
    "vite"
  ],
  "homepage": "https://github.com/tom-auger/stylemakar#readme",
  "bugs": {
    "url": "https://github.com/tom-auger/stylemakar/issues"
  },
  "license": "MIT",
  "author": "Tom Auger <tom@tau.gr>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tom-auger/stylemakar.git"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"tsx watch src/server/index.ts\"",
    "dev:api": "tsx watch src/server/index.ts",
    "eval": "pnpm eval:seed && pnpm eval:rewrite",
    "eval:rewrite": "promptfoo eval -c evals/promptfoo.yaml",
    "eval:seed": "tsx evals/scripts/seed-eval-data.ts",
    "eval:smoke": "pnpm eval:seed && promptfoo eval -c evals/promptfoo-smoke.yaml",
    "eval:view": "promptfoo view",
    "build": "tsc --noEmit && vite build",
    "start": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxfmt . --check",
    "format:fix": "oxfmt . --write",
    "lint": "oxlint -c oxlint.json .",
    "lint:fix": "oxlint -c oxlint.json . --fix",
    "prepare": "node scripts/prepare.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "express": "^4.19.2",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.2",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.0.0",
    "oxlint-tsgolint": "^0.23.0",
    "promptfoo": "^0.121.13",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
